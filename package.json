{
  "name": "quock",
  "version": "0.1.1",
  "description": "Quock — community-built mobile client for Ollama Cloud (unofficial)",
  "author": "Matteo Celani",
  "license": "MIT",
  "private": true,
  "main": "expo-router/entry",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=10"
  },
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "maestro test e2e/",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json}\""
  },
  "expo": {
    "install": {
      "exclude": ["react-native-reanimated", "react-native-worklets"]
    }
  },
  "dependencies": {
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "~5.100.10",
    "clsx": "~2.1.1",
    "expo": "~55.0.24",
    "expo-application": "~55.0.15",
    "expo-auth-session": "~55.0.16",
    "expo-blur": "~55.0.14",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.20",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.10",
    "expo-image-manipulator": "~55.0.17",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-sqlite": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "expo-web-browser": "~55.0.16",
    "lucide-react-native": "~0.577.0",
    "nativewind": "~4.2.5",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-mmkv": "~4.3.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.8.3",
    "tweetnacl": "~1.0.3",
    "zustand": "~5.0.2"
  },
  "devDependencies": {
    "@babel/core": "~7.26.0",
    "@testing-library/react-native": "~13.3.3",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.2.10",
    "eslint": "~9.22.0",
    "eslint-config-expo": "~55.0.1",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.17",
    "prettier": "~3.8.3",
    "react-native-svg-transformer": "~1.5.1",
    "react-test-renderer": "19.2.0",
    "tailwindcss": "~3.4.17",
    "typescript": "~5.9.3"
  }
}
