# Expo + React Native rely on Node's classic module resolver, which does not
# understand pnpm's symlinked `.pnpm/<pkg>@<ver>/node_modules/` layout. Metro
# resolves `react`, `react-native`, and every Expo native module by walking
# parent directories — that walk only finds packages when they sit directly
# under `node_modules/`, so we ask pnpm to write a flat (npm-like) tree.
node-linker=hoisted

# Without `shamefully-hoist=true` some Expo plugins still fail to find their
# peer deps (notably `@react-native/js-polyfills` reached via Metro's setup).
# Together with `node-linker=hoisted` this matches the layout npm produces.
shamefully-hoist=true
